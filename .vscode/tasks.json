{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run OpenMac",
      "type": "process",
      "command": "${workspaceFolder}/Scripts/vscode-run.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Build OpenMac",
      "type": "process",
      "command": "${workspaceFolder}/Scripts/vscode-run.sh",
      "args": ["--build-only"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": "build",
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Clean Build OpenMac",
      "type": "process",
      "command": "${workspaceFolder}/Scripts/vscode-run.sh",
      "args": ["--clean", "--build-only"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": "build",
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      }
    }
  ]
}
